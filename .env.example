# Waxell credentials — required by every example
# Get these from `wax config show` after `wax setup`, or run
# ./scripts/seed-env-from-wax.sh to populate this file automatically
# from your local wax profile.
WAXELL_API_KEY=
WAXELL_API_URL=https://api.waxell.dev

# Provider keys — required by examples that call that provider.
# Each example's README lists which keys it needs.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional — capture LLM input/output content on spans.
# Default is off so prompts/completions stay private.
WAXELL_CAPTURE_CONTENT=0
